# Cyclo runs 100% offline with no configuration. These are OPTIONAL and only
# enable the opt-in, end-to-end-encrypted cloud sync/backup. The server only ever
# stores ciphertext it cannot read. Never commit real values — .env is gitignored.

# Supabase project URL (e.g. https://xxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Supabase anonymous/public key. Safe to expose in a client bundle *only* with
# Row Level Security enabled (see supabase/schema.sql).
VITE_SUPABASE_ANON_KEY=

# Base path for GitHub Pages deploy (defaults to /cyclo/). Match your repo name.
# VITE_BASE=/cyclo/
